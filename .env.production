# ── Logistics Workflow — Production Config ──────────────────
# Copy to .env and edit before deploying

# PostgreSQL
DB_NAME=logistics_workflow
DB_USER=lw_user
DB_PASSWORD=change-me-in-production

# API write-protection token (Bearer auth for POST/PATCH/DELETE)
API_TOKEN=change-me-to-a-secret-token

# Rust logging (info | debug | warn | error)
RUST_LOG=info

# Public port for Nginx (80 | 8080 | custom)
PORT=80
