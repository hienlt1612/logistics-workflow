# ── Logistics Workflow — Production Environment ──────────────
# Copy to .env, fill in secrets, then run: ./deploy.sh start
#
# Generate a strong API_TOKEN: openssl rand -hex 32

DB_NAME=logistics_workflow
DB_USER=lw_user
DB_PASSWORD=change-me-in-production

API_TOKEN=change-me-to-a-secret-token

RUST_LOG=info
PORT=80
